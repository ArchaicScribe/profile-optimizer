generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model ProfileAudit {
  id          String           @id @default(cuid())
  createdAt   DateTime         @default(now())
  source      String           // "export" | "live" | "url"
  rawData     String           // JSON stored as string (SQLite compat)
  auditScore  Int
  signals     Signal[]
  recs        Recommendation[]
}

model Signal {
  id       String       @id @default(cuid())
  text     String
  type     String       // "contract_attractor" | "location_attractor" | "positive" | "neutral"
  severity String       // "high" | "medium" | "low"
  auditId  String
  audit    ProfileAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
}

model Recommendation {
  id       String       @id @default(cuid())
  title    String
  body     String
  priority String       // "high" | "medium" | "low"
  category String       // "keywords" | "location" | "tone" | "experience" | "skills"
  auditId  String
  audit    ProfileAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
}

model UserConfig {
  id              String   @id @default("singleton")
  updatedAt       DateTime @updatedAt
  targetRole      String   @default("Solutions Engineer")
  targetCompanies String   @default("[]") // JSON array e.g. ["Snowflake","Databricks","Google"]
  currentRole     String   @default("Senior Software Engineer")
  yearsExperience Int      @default(6)
  keyBackground   String   @default("") // narrative context injected into all AI prompts
  avoidContext    String   @default("") // things to de-emphasize (e.g. federal experience)
  activeCert      String   @default("AI-102") // cert currently being studied
  certPath        String   @default("[]") // JSON array: ordered cert plan e.g. ["AI-102","AZ-305"]
  certNotes       String   @default("") // freeform notes (not injected into AI - private)
}

model StudyGuide {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())
  jobTitle    String
  company     String
  jdSummary   String?
  chatHistory String          @default("[]") // JSON array of {role, content} messages
  questions   StudyQuestion[]
}

model StudyQuestion {
  id             String            @id @default(cuid())
  guideId        String
  guide          StudyGuide        @relation(fields: [guideId], references: [id], onDelete: Cascade)
  category       String            // "dsa" | "system_design" | "sql" | "ai_ml" | "company_specific"
  difficulty     String            // "easy" | "medium" | "hard"
  topic          String
  prompt         String
  hints          String            @default("[]") // JSON array of hint strings
  status         String            @default("unanswered") // "unanswered" | "got_it" | "struggled"
  reviewCount    Int               @default(0)
  lastReviewedAt DateTime?
  attempts       QuestionAttempt[]
}

model QuestionAttempt {
  id         String        @id @default(cuid())
  createdAt  DateTime      @default(now())
  questionId String
  question   StudyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  guideId    String
  answerText String
  aiFeedback String?       // AI evaluation: what was right, what was missing, what to improve
  score      Int?          // 0-100 AI-assigned score
  status     String        // "got_it" | "struggled"
}

model ScanRun {
  id        String     @id @default(cuid())
  startedAt DateTime   @default(now())
  status    String     // "running" | "complete" | "failed"
  matches   JobMatch[]
}

model JobMatch {
  id         String   @id @default(cuid())
  scannedAt  DateTime @default(now())
  title      String
  company    String
  location   String
  url        String
  board      String   // "indeed" | "linkedin" | "levels" | "dice"
  matchScore Int
  fitReason  String?
  isContract Boolean  @default(false)
  scanRunId  String
  scanRun    ScanRun  @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
}

model CompanyCard {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   String   @unique
  rawData   String   // JSON blob
}
